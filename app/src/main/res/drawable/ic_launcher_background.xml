<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon background — 108 × 108 dp canvas.

    Design: deep-crimson radial gradient that glows from a rich red at the
    centre and fades to near-black at the edges, giving the icon a warm,
    ember-like feel that unifies the three AI-provider accent colours in
    the foreground layer.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base solid fill — prevents any transparent gaps -->
    <path
        android:fillColor="#0B0000"
        android:pathData="M0,0 H108 V108 H0 Z" />

    <!-- Outer dark-crimson layer -->
    <path
        android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="60">
                <item android:offset="0.0" android:color="#8B1A1A" />
                <item android:offset="0.45" android:color="#5C0A0A" />
                <item android:offset="0.75" android:color="#2E0505" />
                <item android:offset="1.0"  android:color="#0B0000" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
